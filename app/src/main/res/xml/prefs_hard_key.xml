<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/label_pref_hard_keyboard">
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:summary="変更すると，ソフトウェアキーボードが正常に動作しない場合があります"
            app:title="@string/label_kana_rule_manager_activity">
            <intent
                android:action="android.intent.action.MAIN"
                android:targetClass="jp.deadend.noname.skk.SKKKanaRuleManager"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_kana_key"
            app:title="かなキー" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_toggle_kana_key"
            app:summary="オンだと，かなモードでかなキーを押すとASCIIモードに戻ります"
            app:title="かなキーをASCIIとのトグルに" />
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_cancel_key"
            app:title="キャンセルキー" />
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_katakana_key"
            app:title="カタカナキー" />
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_ascii_key"
            app:title="ASCIIキー" />
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_zenkaku_key"
            app:title="全角英数キー" />
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_abbrev_key"
            app:title="Abbrevキー" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="@string/pref_use_candidates_view"
            app:summary="補完候補や変換候補を一覧表示します"
            app:title="補完・候補の一覧表示" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_sticky_meta"
            app:summary="shiftを同時押しでなくても効くようにします"
            app:title="Sticky shift" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_sands"
            app:summary="スペースキーをshiftとして使います"
            app:title="SandS" />
    </androidx.preference.PreferenceCategory>
</androidx.preference.PreferenceScreen>

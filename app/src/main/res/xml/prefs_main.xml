<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:title="@string/label_pref_activity">
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="種類別設定">
        <androidx.preference.Preference
            app:fragment="jp.deadend.noname.skk.SKKSettingsActivity$SettingsHardKeyFragment"
            app:icon="@android:drawable/ic_menu_manage"
            app:title="@string/label_pref_hard_keyboard" />
        <androidx.preference.Preference
            app:fragment="jp.deadend.noname.skk.SKKSettingsActivity$SettingsSoftKeyFragment"
            app:icon="@android:drawable/ic_menu_manage"
            app:title="@string/label_pref_soft_keyboard" />
    </androidx.preference.PreferenceCategory>
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="共通設定">
        <androidx.preference.DropDownPreference
            app:defaultValue="jp"
            app:dialogTitle="句読点のタイプ"
            app:entries="@array/kutouten_entries"
            app:entryValues="@array/kutouten_values"
            app:icon="@android:drawable/ic_dialog_dialer"
            app:key="@string/pref_kutouten_type"
            app:title="句読点のタイプ"
            app:useSimpleSummaryProvider="true" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="@string/pref_prefix_mark"
            app:summary="不意にフォーカスが外れて確定されることが多い場合は表示しないことをお勧めします"
            app:title="変換中の▽や▼を表示" />
    </androidx.preference.PreferenceCategory>
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="SKK 辞書管理">
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_input_add"
            app:title="システム辞書の管理">
            <intent
                android:action="android.intent.action.MAIN"
                android:targetClass="jp.deadend.noname.skk.SKKDictManager"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_menu_manage"
            app:title="@string/label_dict_tool_activity">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_user"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_menu_manage"
            app:title="@string/label_ascii_tool_activity">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_ascii"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_menu_manage"
            app:title="@string/label_emoji_tool_activity">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_emoji"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
    </androidx.preference.PreferenceCategory>
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/label_dict_manager_reset">
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_notification_clear_all"
            app:summary="何も登録されていない状態にします"
            app:title="@string/label_dict_tool_recreate">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_user_recreate"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_notification_clear_all"
            app:summary="初期辞書だけの状態にします"
            app:title="@string/label_ascii_tool_recreate">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_ascii_recreate"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
        <androidx.preference.Preference
            app:icon="@android:drawable/ic_notification_clear_all"
            app:summary="初期辞書だけの状態にします"
            app:title="@string/label_emoji_tool_recreate">
            <intent
                android:action="android.intent.action.MAIN"
                android:data="@string/dict_name_emoji_recreate"
                android:targetClass="jp.deadend.noname.skk.SKKUserDictTool"
                android:targetPackage="jp.deadend.noname.skk" />
        </androidx.preference.Preference>
    </androidx.preference.PreferenceCategory>
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="候補表示">
        <androidx.preference.SeekBarPreference
            android:max="60"
            app:defaultValue="30"
            app:iconSpaceReserved="false"
            app:key="@string/pref_candidates_size"
            app:min="12"
            app:showSeekBarValue="true"
            app:title="候補表示の文字サイズ" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_candidates_min_height"
            app:summary="変換中にアプリがリサイズしませんが一部隠れます"
            app:title="候補表示をアプリ上に重ねて伸ばす" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="@string/pref_fuzzy_suggestion"
            app:summary="濁音や半濁音にした単語も提案します (「ひんく」で「ぴんぐ」も出る)\n英字ではqwertyの隣接キーも提案します"
            app:title="あいまい候補" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:dependency="@string/pref_fuzzy_suggestion"
            app:key="@string/pref_fuzzier_suggestion"
            app:summary="ア段は段も変えて検索します (「あたま」で「いとま」も出る)"
            app:title="もっとあいまい候補" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_suggest_okuri"
            app:summary="「おくr」等を提案に含めます (次に「い」で「送り」になり，「り」は「送っり」になるので注意)"
            app:title="送りありの提案" />
        <androidx.preference.SeekBarPreference
            android:max="10"
            app:defaultValue="2"
            app:iconSpaceReserved="false"
            app:key="@string/pref_candidates_normal_lines"
            app:min="1"
            app:showSeekBarValue="true"
            app:title="候補表示の行数 (通常)" />
        <androidx.preference.SeekBarPreference
            android:max="10"
            app:defaultValue="4"
            app:iconSpaceReserved="false"
            app:key="@string/pref_candidates_emoji_lines"
            app:min="1"
            app:showSeekBarValue="true"
            app:title="候補表示の行数 (絵文字)" />
    </androidx.preference.PreferenceCategory>
    <androidx.preference.PreferenceCategory
        app:icon="@android:drawable/ic_dialog_alert"
        app:title="@string/label_log_viewer">
        <androidx.preference.Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_log_viewer"
            app:summary="最新のクラッシュ記録があれば表示され，再度タップでコピーできます"
            app:title="ここをタップ" />
    </androidx.preference.PreferenceCategory>
</androidx.preference.PreferenceScreen>

<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:app="http://schemas.android.com/apk/res-auto"
    app:hGap="0dip"
    app:height="8%p"
    app:vGap="0dip"
    app:width="20%p">
    <Row>
        <Key
            app:codes="-1,-7"
            app:icon="@drawable/ic_keyboard_shift"
            app:sticky="true" />
        <Key
            app:codes="-201"
            app:label="あ" />
        <Key
            app:codes="-202"
            app:label="か" />
        <Key
            app:codes="-203"
            app:label="さ" />
        <Key
            app:codes="-5"
            app:icon="@drawable/ic_keyboard_backspace"
            app:repeatable="true" />
    </Row>
    <Row>
        <Key
            app:codes="-1001"
            app:icon="@drawable/ic_keyboard_arrow_left"
            app:repeatable="true" />
        <Key
            app:codes="-204"
            app:label="た" />
        <Key
            app:codes="-205"
            app:label="な" />
        <Key
            app:codes="-206"
            app:label="は" />
        <Key
            app:codes="-1002"
            app:icon="@drawable/ic_keyboard_arrow_right"
            app:repeatable="true" />
    </Row>
    <Row>
        <Key
            app:codes="-1005"
            app:label="(10\n：カナ&gt;\n声)※変更されます" />
        <Key
            app:codes="-207"
            app:label="ま" />
        <Key
            app:codes="-208"
            app:label="や" />
        <Key
            app:codes="-209"
            app:label="ら" />
        <Key
            app:codes="-1004"
            app:icon="@drawable/ic_keyboard_space_bar"
            app:repeatable="true" />
    </Row>
    <Row app:edge="bottom">
        <Key
            app:codes="-1003"
            app:label="(全角ａ\n☻abc記\nqwerty)※変更されます" />
        <Key
            app:codes="-1006"
            app:label="(CXL\n　゛小　゜\n▽)※変更されます" />
        <Key
            app:codes="-210"
            app:label="ん\nをわー\n〜" />
        <Key
            app:codes="-211"
            app:label="(？\n。、！\n…)※変更されます" />
        <Key
            app:codes="-1007"
            app:icon="@drawable/ic_keyboard_return" />
    </Row>
</Keyboard>

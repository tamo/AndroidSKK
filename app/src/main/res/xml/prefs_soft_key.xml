<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.preference.Preference
        app:icon="@android:drawable/ic_dialog_info"
        app:summary="入力欄タイプにより状態が変化することがあります"
        app:title="一部の設定はハードウェアキーボードにも有効です" />
    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/label_pref_soft_keyboard">
        <androidx.preference.DropDownPreference
            app:defaultValue="auto"
            app:entries="@array/use_soft_key_entries"
            app:entryValues="@array/use_soft_key_values"
            app:icon="@android:drawable/ic_dialog_dialer"
            app:key="@string/pref_use_soft_key"
            app:title="表示の有無"
            app:useSimpleSummaryProvider="true" />
        <androidx.preference.DropDownPreference
            app:defaultValue="switch"
            app:entries="@array/soft_keyboard_type_entries"
            app:entryValues="@array/soft_keyboard_type_values"
            app:icon="@android:drawable/ic_dialog_dialer"
            app:key="@string/pref_soft_keyboard_type"
            app:title="種類の切替"
            app:useSimpleSummaryProvider="true" />
        <androidx.preference.CheckBoxPreference
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="@string/pref_show_status_icon"
            app:summary="ソフトウェアキーボード使用時にも「あ」「ア」「Ａ」「ab」といった状態を表示します"
            app:title="ステータスアイコンの表示" />

        <androidx.preference.PreferenceCategory
            app:iconSpaceReserved="false"
            app:title="日本語キーボード">
            <androidx.preference.Preference
                app:icon="@android:drawable/ic_menu_edit"
                app:title="@string/label_flick_rule_manager_activity">
                <intent
                    android:action="android.intent.action.MAIN"
                    android:targetClass="jp.deadend.noname.skk.SKKFlickRuleManager"
                    android:targetPackage="jp.deadend.noname.skk" />
            </androidx.preference.Preference>
            <androidx.preference.CheckBoxPreference
                app:defaultValue="true"
                app:iconSpaceReserved="false"
                app:key="@string/pref_use_popup"
                app:summary="フリック入力用のガイドを表示します"
                app:title="ポップアップの表示" />
            <androidx.preference.CheckBoxPreference
                app:defaultValue="true"
                app:dependency="@string/pref_use_popup"
                app:key="@string/pref_popup_on_press"
                app:summary="オフだと長押しでのみ表示します (長押し判定までの時間は別途変更可能)"
                app:title="ポップアップの即時表示" />
            <androidx.preference.CheckBoxPreference
                app:defaultValue="true"
                app:dependency="@string/pref_use_popup"
                app:key="@string/pref_fixed_popup"
                app:summary="オンだと常に上部の同じ場所，オフだと指の近くに表示します"
                app:title="ポップアップの固定" />
            <androidx.preference.SeekBarPreference
                android:max="200"
                app:defaultValue="70"
                app:dependency="@string/pref_use_popup"
                app:key="@string/pref_finger_offset"
                app:min="-200"
                app:showSeekBarValue="true"
                app:summary="固定オフでこの値が 0 だと指の真下になり実質見えません"
                app:title="ポップアップの上下ずらし" />
            <androidx.preference.CheckBoxPreference
                app:defaultValue="true"
                app:iconSpaceReserved="false"
                app:key="@string/pref_use_small_k"
                app:summary="「◻゙□゚」で「かけカケ」を小さくします"
                app:title="小書きカケの使用" />
        </androidx.preference.PreferenceCategory>

        <androidx.preference.PreferenceCategory
            app:iconSpaceReserved="false"
            app:title="長押し">
            <androidx.preference.SeekBarPreference
                android:max="3000"
                app:defaultValue="500"
                app:iconSpaceReserved="false"
                app:key="@string/pref_long_press_timeout"
                app:min="100"
                app:seekBarIncrement="50"
                app:showSeekBarValue="true"
                app:summary="1000 で 1 秒です"
                app:title="長押し判定までの時間" />
            <androidx.preference.CheckBoxPreference
                app:defaultValue="false"
                app:iconSpaceReserved="false"
                app:key="@string/pref_mini_keyboard"
                app:summary="英字キーボードのアルファベットや . を長押しでポップアップを出します"
                app:title="アクセント文字の使用" />
        </androidx.preference.PreferenceCategory>

        <androidx.preference.PreferenceCategory
            app:iconSpaceReserved="false"
            app:title="サイズ">
            <androidx.preference.SeekBarPreference
                android:max="70"
                app:defaultValue="24"
                app:iconSpaceReserved="false"
                app:key="@string/pref_flick_sensitivity"
                app:min="10"
                app:showSeekBarValue="true"
                app:summary="大きいほど鈍いです"
                app:title="フリック感度" />
            <androidx.preference.SeekBarPreference
                android:max="200"
                app:defaultValue="100"
                app:iconSpaceReserved="false"
                app:key="@string/pref_key_label_zoom"
                app:min="10"
                app:showSeekBarValue="true"
                app:title="キー表面の文字の大きさ（％）" />
            <androidx.preference.SeekBarPreference
                android:max="100"
                app:defaultValue="30"
                app:iconSpaceReserved="false"
                app:key="@string/pref_key_height_port"
                app:min="1"
                app:showSeekBarValue="true"
                app:summary="幅は候補表示を2本指でつまんで調整できます"
                app:title="縦画面の高さに対するキーボードの高さ割合（％）" />
            <androidx.preference.SeekBarPreference
                android:max="100"
                app:defaultValue="50"
                app:iconSpaceReserved="false"
                app:key="@string/pref_key_height_land"
                app:min="1"
                app:showSeekBarValue="true"
                app:summary="幅は候補表示を2本指でつまんで調整できます"
                app:title="横画面の高さに対するキーボードの高さ割合（％）" />
            <androidx.preference.SeekBarPreference
                android:max="50"
                app:defaultValue="15"
                app:iconSpaceReserved="false"
                app:key="@string/pref_key_padding_bottom"
                app:min="0"
                app:showSeekBarValue="true"
                app:summary="最下段から下にスワイプしやすくするなど"
                app:title="キーボードの高さに対する底上げ部分の割合（％）" />
            <androidx.preference.SeekBarPreference
                android:max="400"
                app:defaultValue="200"
                app:iconSpaceReserved="false"
                app:key="@string/pref_key_width_qwerty_zoom"
                app:min="100"
                app:showSeekBarValue="true"
                app:summary="日本語キーボードに対する割合（％）"
                app:title="英字キーボード幅の倍率" />
        </androidx.preference.PreferenceCategory>

        <androidx.preference.PreferenceCategory
            app:iconSpaceReserved="false"
            app:title="入力欄のタイプ">
            <androidx.preference.DropDownPreference
                app:defaultValue="ignore"
                app:entries="@array/input_type_entries"
                app:entryValues="@array/input_type_values"
                app:icon="@android:drawable/ic_dialog_dialer"
                app:key="@string/pref_type_uri"
                app:title="アドレスバー等のキーボード"
                app:useSimpleSummaryProvider="true" />
            <androidx.preference.DropDownPreference
                app:defaultValue="flick-num"
                app:entries="@array/input_type_entries"
                app:entryValues="@array/input_type_values"
                app:icon="@android:drawable/ic_dialog_dialer"
                app:key="@string/pref_type_number"
                app:title="数字入力欄のキーボード"
                app:useSimpleSummaryProvider="true" />
            <androidx.preference.DropDownPreference
                app:defaultValue="flick-num"
                app:entries="@array/input_type_entries"
                app:entryValues="@array/input_type_values"
                app:icon="@android:drawable/ic_dialog_dialer"
                app:key="@string/pref_type_phone"
                app:title="電話番号欄のキーボード"
                app:useSimpleSummaryProvider="true" />
            <androidx.preference.DropDownPreference
                app:defaultValue="qwerty"
                app:entries="@array/input_type_entries"
                app:entryValues="@array/input_type_values"
                app:icon="@android:drawable/ic_dialog_dialer"
                app:key="@string/pref_type_password"
                app:title="パスワード欄のキーボード"
                app:useSimpleSummaryProvider="true" />
            <androidx.preference.DropDownPreference
                app:defaultValue="ignore"
                app:entries="@array/input_type_entries"
                app:entryValues="@array/input_type_values"
                app:icon="@android:drawable/ic_dialog_dialer"
                app:key="@string/pref_type_text"
                app:title="設定されていないテキスト欄のキーボード"
                app:useSimpleSummaryProvider="true" />

            <androidx.preference.PreferenceCategory
                app:iconSpaceReserved="false"
                app:title="その他の動作">
                <androidx.preference.CheckBoxPreference
                    app:defaultValue="false"
                    app:iconSpaceReserved="false"
                    app:key="@string/pref_over_edge"
                    app:summary="オフだと無駄なカーソル移動は無効化します"
                    app:title="端を越えた左右移動の試行" />
                <androidx.preference.CheckBoxPreference
                    app:defaultValue="false"
                    app:iconSpaceReserved="false"
                    app:key="@string/pref_forbid_paste"
                    app:summary="誤操作を防ぐため貼り付け動作を無効化します"
                    app:title="貼り付けの禁止" />
                <androidx.preference.CheckBoxPreference
                    app:defaultValue="true"
                    app:iconSpaceReserved="false"
                    app:key="@string/pref_use_del"
                    app:summary="オンだと削除キー処理をアプリにまかせ，オフだと自前で文字を消そうと試みます"
                    app:title="キー操作として削除" />
            </androidx.preference.PreferenceCategory>
        </androidx.preference.PreferenceCategory>
    </androidx.preference.PreferenceCategory>
</androidx.preference.PreferenceScreen>

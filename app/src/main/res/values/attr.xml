<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="width" format="dimension|fraction" />
    <attr name="height" format="dimension|fraction" />
    <attr name="hGap" format="dimension|fraction" />
    <attr name="vGap" format="dimension|fraction" />
    <attr name="popupLayout" format="reference" />
    <attr name="edge" format="integer">
        <flag name="left" value="1" />
        <flag name="right" value="2" />
        <flag name="top" value="4" />
        <flag name="bottom" value="8" />
    </attr>

    <declare-styleable name="KeyboardView">
        <attr name="keyboardViewStyle" format="reference" />
        <attr name="keyBackground" format="reference" />
        <attr name="keyCornerRadius" format="dimension" />
        <attr name="keyTextSize" format="dimension" />
        <attr name="labelTextSize" format="dimension" />
        <attr name="keyTextColor" format="color" />
        <attr name="keyPreviewLayout" format="reference" />
        <attr name="keyPreviewOffset" format="dimension" />
        <attr name="keyPreviewHeight" format="dimension" />
        <!-- Amount to offset the touch Y coordinate by for bias correction. -->
        <attr name="verticalCorrection" format="dimension" />
        <attr name="popupLayout" />
    </declare-styleable>

    <declare-styleable name="KeyboardViewPreviewState">
        <attr name="state_long_pressable" format="boolean" />
    </declare-styleable>

    <declare-styleable name="Keyboard">
        <attr name="width" />
        <attr name="height" />
        <attr name="hGap" />
        <attr name="vGap" />
        <attr name="popupLayout" />
    </declare-styleable>

    <declare-styleable name="Keyboard_Row">
        <attr name="width" />
        <attr name="height" />
        <attr name="hGap" />
        <attr name="vGap" />
        <attr name="edge" />
    </declare-styleable>

    <declare-styleable name="Keyboard_Key">
        <attr name="width" />
        <attr name="height" />
        <attr name="hGap" />
        <!-- The Unicode value or comma-separated values that this key outputs. -->
        <attr name="codes" format="integer|string" />
        <attr name="shiftedCode" format="integer" />
        <attr name="downCode" format="integer" />
        <attr name="popupLayout" />
        <!-- The characters to display in the popup keyboard -->
        <attr name="popup" format="string" />
        <attr name="edge" />
        <!-- Whether this is a toggle key -->
        <attr name="sticky" format="boolean" />
        <attr name="repeatable" format="boolean" />
        <attr name="label" format="string" />
        <!-- Label for up flick state -->
        <attr name="shifted" format="string" />
        <!-- Label for down flick state -->
        <attr name="down" format="string" />
        <attr name="icon" format="reference" />
    </declare-styleable>

    <declare-styleable name="CandidatesViewImageButton">
        <attr name="side" format="string" />
    </declare-styleable>
</resources>
